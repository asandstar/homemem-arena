import { useState, useEffect, useCallback } from 'react'
import { useGameStore } from '../../store/useGameStore'
import { useSessionStore } from '../../store/useSessionStore'
import { sharedRooms } from '../../data/rooms'
import { Minimap } from './Minimap'
import type { GoalSpec } from '../../types/task'
import { formatDuration } from '../../utils/format'
import { Brain, Lock, Unlock, Trash2, Package, Keyboard, CheckCircle2, Clock, AlertTriangle, Zap, Target, ChevronDown, ChevronUp, X, AlertCircle, Skull } from 'lucide-react'

export function HUD() {
  const { 
    task, currentRoom, elapsedMs, heldEntityId, entities, 
    robotPosition, visitedRooms, chaosValue, score, combo, memorySlots,
    lockMemorySlot, clearMemorySlot, flashingSlotIndex,
    feedback, hideFeedback, savingMemorySlotIndex
  } = useGameStore()
  const { currentSession } = useSessionStore()
  const [showTaskPanel, setShowTaskPanel] = useState(true)
  const [eventLogCollapsed, setEventLogCollapsed] = useState(true)
  const [isShaking, setIsShaking] = useState(false)

  useEffect(() => {
    if (feedback) {
      const timeout = setTimeout(() => {
        hideFeedback()
      }, feedback.type === 'event' ? 4000 : 1500)
      return () => clearTimeout(timeout)
    }
  }, [feedback, hideFeedback])

  useEffect(() => {
    if (chaosValue > 70) {
      const interval = setInterval(() => {
        setIsShaking(true)
        setTimeout(() => setIsShaking(false), 200)
      }, 1500 + Math.random() * 1000)
      return () => clearInterval(interval)
    }
  }, [chaosValue])

  const handleKeyDown = useCallback((e: KeyboardEvent) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return

    switch (e.key.toLowerCase()) {
      case 'tab':
        e.preventDefault()
        setShowTaskPanel((prev) => !prev)
        break
      case 'v':
        useGameStore.getState().toggleViewMode()
        break
    }
  }, [])

  useEffect(() => {
    window.addEventListener('keydown', handleKeyDown)
    return () => window.removeEventListener('keydown', handleKeyDown)
  }, [handleKeyDown])

  if (!task) return null

  const roomSpec = sharedRooms[currentRoom]
  const heldEntity = entities.find((e) => e.id === heldEntityId)
  
  const events = currentSession?.events ?? []
  const recentEvents = events.slice(-5)

  const achievedGoals = task.goals.filter((g: GoalSpec) => {
    const entities = useGameStore.getState().entities
    return g.predicate(entities.map((e) => ({
      configId: e.configId,
      status: e.status,
      currentRoom: e.currentRoom,
      placedIn: e.placedIn,
      category: e.category,
      properties: e.properties,
    })))
  }).length
  const totalGoals = task.goals.length
  const progress = totalGoals > 0 ? (achievedGoals / totalGoals) * 100 : 0

  const chaosColor = chaosValue < 30 ? 'from-green-500 to-emerald-500' : chaosValue < 60 ? 'from-yellow-500 to-orange-500' : 'from-red-500 to-pink-500'

  const getRating = (score: number): string => {
    if (score >= 900) return 'S'
    if (score >= 700) return 'A'
    if (score >= 500) return 'B'
    if (score >= 300) return 'C'
    return 'D'
  }

  const chaosWarning = chaosValue > 70

  return (
    <div 
      className={`absolute inset-0 pointer-events-none ${chaosWarning ? 'animate-pulse' : ''}`}
      style={{
        ...(chaosWarning && {
          animation: isShaking ? 'hud-shake 0.2s ease-in-out' : 'none',
          filter: `hue-rotate(${(chaosValue - 70) * 0.5}deg) saturate(${1 + (chaosValue - 70) * 0.01})`,
        }),
      }}
    >
      {/* 左上角：关卡名、任务 checklist、剩余时间 */}
      <div className="absolute top-4 left-4 pointer-events-auto">
        <div className="bg-slate-900/80 backdrop-blur-md rounded-xl p-4 shadow-xl border border-slate-700/50">
          <div className="flex items-center justify-between mb-3">
            <h2 className="text-lg font-bold text-white flex items-center gap-2">
              <Target size={18} className="text-purple-400" />
              {task.name}
            </h2>
            <div className="flex items-center gap-2 text-xs text-slate-400">
              <Clock size={14} />
              <span>{formatDuration(elapsedMs)}</span>
            </div>
          </div>

          {showTaskPanel && (
            <div className="space-y-2">
              {task.goals.map((goal: GoalSpec) => {
                const entities = useGameStore.getState().entities
                const isAchieved = goal.predicate(entities.map((e) => ({
                  configId: e.configId,
                  status: e.status,
                  currentRoom: e.currentRoom,
                  placedIn: e.placedIn,
                  category: e.category,
                  properties: e.properties,
                })))
                return (
                  <div key={goal.id} className="flex items-start gap-2">
                    <span className={`mt-1 w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 ${isAchieved ? 'bg-green-500 border-green-500' : 'border-slate-500'}`}>
                      {isAchieved && <CheckCircle2 size={12} className="text-white" />}
                    </span>
                    <span className={`text-sm ${isAchieved ? 'text-slate-400 line-through' : 'text-slate-200'}`}>
                      {goal.description}
                    </span>
                  </div>
                )
              })}
              <div className="text-xs text-slate-500 mt-2">按 Tab 隐藏</div>
            </div>
          )}
        </div>
      </div>

      {/* 顶部中央：混乱值、进度条、Combo */}
      <div className="absolute top-4 left-1/2 -translate-x-1/2 pointer-events-auto">
        <div className="bg-slate-900/80 backdrop-blur-md rounded-xl p-4 shadow-xl border border-slate-700/50 w-80">
          <div className="flex items-center justify-between mb-3">
            <div className="flex items-center gap-2">
              <AlertTriangle size={16} className={chaosValue > 70 ? 'text-red-400 animate-pulse' : chaosValue > 40 ? 'text-yellow-400' : 'text-green-400'} />
              <span className="text-sm font-semibold text-white">混乱值</span>
            </div>
            <span className={`text-sm font-bold ${chaosValue > 70 ? 'text-red-400' : chaosValue > 40 ? 'text-yellow-400' : 'text-green-400'}`}>
              {Math.floor(chaosValue)}%
            </span>
          </div>
          <div className="h-3 bg-slate-700 rounded-full overflow-hidden mb-3">
            <div 
              className={`h-full bg-gradient-to-r ${chaosColor} transition-all duration-300`}
              style={{ width: `${chaosValue}%` }}
            />
          </div>

          <div className="flex items-center justify-between">
            <div className="flex items-center gap-2">
              <div className="w-20 h-2 bg-slate-700 rounded-full overflow-hidden">
                <div 
                  className="h-full bg-gradient-to-r from-purple-500 to-pink-500 transition-all duration-300"
                  style={{ width: `${progress}%` }}
                />
              </div>
              <span className="text-xs text-slate-400">{achievedGoals}/{totalGoals}</span>
            </div>

            {combo > 0 && (
              <div className="flex items-center gap-1 bg-yellow-500/20 px-2 py-1 rounded-full">
                <Zap size={14} className="text-yellow-400" />
                <span className="text-yellow-400 font-bold">{combo} COMBO!</span>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* 右上角：得分、评级预估、当前持有物体 */}
      <div className="absolute top-4 right-4 pointer-events-auto">
        <div className="bg-slate-900/80 backdrop-blur-md rounded-xl p-4 shadow-xl border border-slate-700/50">
          <div className="flex items-center gap-4">
            <div className="text-center">
              <div className="text-xs text-slate-400">得分</div>
              <div className="text-2xl font-bold text-white">{score}</div>
            </div>
            <div className="w-px h-10 bg-slate-700" />
            <div className="text-center">
              <div className="text-xs text-slate-400">评级</div>
              <div className={`text-2xl font-bold ${getRating(score) === 'S' ? 'text-yellow-400' : getRating(score) === 'A' ? 'text-green-400' : getRating(score) === 'B' ? 'text-blue-400' : getRating(score) === 'C' ? 'text-purple-400' : 'text-slate-400'}`}>
                {getRating(score)}
              </div>
            </div>
            <div className="w-px h-10 bg-slate-700" />
            <div className="text-center">
              <div className="text-xs text-slate-400">位置</div>
              <div className="text-sm font-semibold text-slate-200">{roomSpec?.name ?? currentRoom}</div>
            </div>
          </div>

          {heldEntity && (
            <div className="mt-3 pt-3 border-t border-slate-700 flex items-center gap-2">
              <Package size={16} className="text-purple-400" />
              <span className="text-sm text-white">持有: {heldEntity.name}</span>
            </div>
          )}
        </div>
      </div>

      {/* 左下角：操作提示 */}
      <div className="absolute bottom-4 left-4 pointer-events-auto">
        <div className="bg-slate-900/70 backdrop-blur-sm rounded-lg px-3 py-2 text-xs shadow-lg border border-slate-700/50">
          <div className="flex items-center gap-2 mb-2">
            <Keyboard size={12} className="text-purple-400" /> 
            <span className="font-semibold text-white">操作提示</span>
          </div>
          <div className="grid grid-cols-3 gap-x-3 gap-y-1">
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">WASD</kbd>
              <span className="text-slate-400">移动</span>
            </div>
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">V</kbd>
              <span className="text-slate-400">视角</span>
            </div>
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">Tab</kbd>
              <span className="text-slate-400">任务</span>
            </div>
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">E</kbd>
              <span className="text-slate-400">存记忆</span>
            </div>
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">F</kbd>
              <span className="text-slate-400">交互</span>
            </div>
            <div className="flex items-center gap-1">
              <kbd className="px-1.5 py-0.5 bg-slate-700 rounded text-white text-[10px] font-mono">ESC</kbd>
              <span className="text-slate-400">退出</span>
            </div>
          </div>
        </div>
      </div>

      {/* 右下角：小地图 */}
      <div className="absolute bottom-4 right-4 pointer-events-auto">
        <div className="bg-slate-900/70 backdrop-blur-sm rounded-lg p-2 shadow-lg border border-slate-700/50">
          <Minimap
            currentRoom={currentRoom}
            visitedRooms={Array.from(visitedRooms)}
            robotPosition={robotPosition}
            observedObjects={[]}
          />
        </div>
      </div>

      {/* 底部中央：记忆槽 UI */}
      <div className="absolute bottom-4 left-1/2 -translate-x-1/2 pointer-events-auto">
        <div className="bg-slate-900/80 backdrop-blur-md rounded-xl p-3 shadow-xl border border-slate-700/50">
          <div className="flex items-center gap-1 mb-2">
            <Brain size={14} className="text-purple-400" />
            <span className="text-xs text-slate-400">记忆槽 (按 E 保存)</span>
          </div>
          <div className="flex gap-2">
            {memorySlots.map((slot, index) => (
              <div
                key={index}
                className={`relative w-24 h-14 rounded-lg border-2 p-2 transition-all ${
                  savingMemorySlotIndex === index
                    ? 'animate-memory-save border-purple-400 bg-purple-900/50 shadow-lg shadow-purple-500/50'
                    : flashingSlotIndex === index
                      ? 'animate-pulse border-green-400 bg-green-900/30 shadow-lg shadow-green-500/30'
                      : slot
                        ? slot.locked
                          ? 'bg-purple-900/50 border-purple-500'
                          : 'bg-slate-800/50 border-slate-500 hover:border-purple-400'
                        : 'bg-slate-800/30 border-dashed border-slate-600'
                }`}
              >
                {slot ? (
                  <>
                    <button
                      onClick={() => lockMemorySlot(index)}
                      className="absolute top-1 right-1 p-0.5 rounded hover:bg-white/10"
                    >
                      {slot.locked ? (
                        <Lock size={10} className="text-purple-400" />
                      ) : (
                        <Unlock size={10} className="text-slate-400" />
                      )}
                    </button>
                    <button
                      onClick={() => clearMemorySlot(index)}
                      className="absolute top-1 right-10 p-0.5 rounded hover:bg-red-500/20"
                    >
                      <Trash2 size={10} className="text-red-400" />
                    </button>
                    <div className="text-xs text-white mt-3">
                      <div className="font-semibold truncate">{slot.objectName}</div>
                      <div className="text-slate-400 text-[10px]">{slot.roomName}</div>
                    </div>
                  </>
                ) : (
                  <div className="w-full h-full flex items-center justify-center">
                    <span className="text-slate-600 text-xs">空槽位</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* 右侧可折叠：事件提示 */}
      <div className="absolute top-24 right-4 pointer-events-auto w-64">
        <div className={`bg-slate-900/70 backdrop-blur-sm rounded-lg overflow-hidden shadow-lg border border-slate-700/50 transition-all duration-300 ${eventLogCollapsed ? 'max-h-8' : 'max-h-48'}`}>
          <button
            onClick={() => setEventLogCollapsed(!eventLogCollapsed)}
            className="w-full px-3 py-2 flex items-center justify-between text-slate-300 text-xs hover:bg-slate-800/50"
          >
            <span className="font-semibold">事件日志</span>
            {eventLogCollapsed ? <ChevronDown size={14} /> : <ChevronUp size={14} />}
          </button>
          {!eventLogCollapsed && (
            <div className="px-3 pb-3 space-y-2 max-h-40 overflow-y-auto">
              {recentEvents.length === 0 ? (
                <div className="text-xs text-slate-500 py-2">暂无事件</div>
              ) : (
                recentEvents.map((event, index) => {
                  const displayText = 'message' in event ? event.message : 'description' in event ? event.description : (event as any).type
                  return (
                    <div key={index} className="text-xs text-slate-300 flex items-start gap-2">
                      <span className="text-slate-500 flex-shrink-0">[步 {event.step}]</span>
                      <span>{String(displayText)}</span>
                    </div>
                  )
                })
              )}
            </div>
          )}
        </div>
      </div>

      {/* Combo 浮动文字 */}
      {feedback?.type === 'combo' && (
        <div className="absolute top-1/3 left-1/2 -translate-x-1/2 pointer-events-none">
          <div className="animate-float-up text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 via-orange-500 to-red-500 drop-shadow-lg">
            {feedback.message}
          </div>
        </div>
      )}

      {/* 放置成功/失败闪烁反馈 */}
      {(feedback?.type === 'success' || feedback?.type === 'error') && (
        <div className={`absolute inset-0 pointer-events-none animate-flash ${
          feedback.type === 'success' ? 'bg-green-500/20' : 'bg-red-500/20'
        }`}>
          <div className="absolute inset-0 border-4 border-white/30 rounded-lg" 
               style={{ borderColor: feedback.type === 'success' ? 'rgba(34, 197, 94, 0.5)' : 'rgba(239, 68, 68, 0.5)' }}>
          </div>
        </div>
      )}

      {/* 捣乱事件剧情提示弹窗 */}
      {feedback?.type === 'event' && (
        <div className="absolute inset-0 pointer-events-none flex items-center justify-center bg-black/50 backdrop-blur-sm">
          <div className="bg-slate-900/95 border border-red-500/50 rounded-xl p-6 max-w-md w-full mx-4 shadow-2xl animate-event-popup pointer-events-auto">
            <button onClick={hideFeedback} className="absolute top-3 right-3 p-1 hover:bg-red-500/20 rounded-lg">
              <X size={18} className="text-red-400" />
            </button>
            <div className="flex items-center gap-3 mb-4">
              <div className="p-2 bg-red-500/20 rounded-lg">
                <Skull size={24} className="text-red-400" />
              </div>
              <h3 className="text-lg font-bold text-white">异常事件</h3>
            </div>
            <p className="text-slate-300 text-sm leading-relaxed mb-4">
              {feedback.message}
            </p>
            <div className="flex items-center gap-2 text-xs text-red-400">
              <AlertCircle size={14} />
              <span>混乱值上升！</span>
            </div>
          </div>
        </div>
      )}

      <style>{`
        @keyframes hud-shake {
          0%, 100% { transform: translateX(0); }
          10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
          20%, 40%, 60%, 80% { transform: translateX(4px); }
        }
        @keyframes float-up {
          0% { opacity: 1; transform: translateY(0) scale(0.8); }
          50% { opacity: 1; transform: translateY(-30px) scale(1.2); }
          100% { opacity: 0; transform: translateY(-80px) scale(1); }
        }
        @keyframes flash {
          0% { opacity: 0; }
          20% { opacity: 1; }
          40% { opacity: 0.5; }
          60% { opacity: 1; }
          80% { opacity: 0.3; }
          100% { opacity: 0; }
        }
        @keyframes event-popup {
          0% { opacity: 0; transform: scale(0.9) translateY(20px); }
          100% { opacity: 1; transform: scale(1) translateY(0); }
        }
        @keyframes memory-save {
          0% { transform: scale(0.8); opacity: 0; box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
          30% { transform: scale(1.1); box-shadow: 0 0 0 10px rgba(168, 85, 247, 0); }
          60% { transform: scale(1); box-shadow: 0 0 0 0 rgba(168, 85, 247, 0); }
          100% { transform: scale(1); opacity: 1; }
        }
        .animate-float-up {
          animation: float-up 1.5s ease-out forwards;
        }
        .animate-flash {
          animation: flash 1.5s ease-out forwards;
        }
        .animate-event-popup {
          animation: event-popup 0.3s ease-out forwards;
        }
        .animate-memory-save {
          animation: memory-save 1.5s ease-out forwards;
        }
      </style>
    </div>
  )
}
